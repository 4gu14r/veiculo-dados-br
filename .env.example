POSTGRES_DB=veiculos
POSTGRES_USER=veiculos
POSTGRES_PASSWORD=troca_isso_aqui

# Montada automaticamente pelo docker-compose em dev
# Em produção (Render) aponta pro Neon/Supabase
DATABASE_URL=postgresql+psycopg://veiculos:troca_isso_aqui@db:5432/veiculos

ENVIRONMENT=development

# Origens permitidas no CORS (em produção, troca por seu domínio)
CORS_ORIGINS=["*"]
